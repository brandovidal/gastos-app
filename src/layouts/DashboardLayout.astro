---
import Layout from "./Layout.astro";
import { Sidebar } from "@/shared/components/Sidebar";
import { ThemeToggle } from "@/shared/components/ThemeToggle";
import { MobileNav } from "@/shared/components/MobileNav";
import { MonthNavigator } from "@/shared/components/MonthNavigator";
import { SalaryEditor } from "@/shared/components/SalaryEditor";
import { Toaster } from "@/ui/sonner";

interface Props {
  title?: string;
}

const { title = "Gastos App" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Layout title={title}>
  <div class="flex h-screen overflow-hidden">
    <Sidebar currentPath={currentPath} />

    <div class="flex flex-1 flex-col overflow-hidden">
      <header class="flex h-16 items-center justify-between border-b px-4 md:px-6">
        <div class="flex items-center gap-2">
          <MobileNav client:load currentPath={currentPath} />
          <h1 class="text-lg font-semibold">{title}</h1>
        </div>
        <div class="flex items-center gap-3">
          <MonthNavigator client:load />
          <div class="hidden sm:block h-4 w-px bg-border" />
          <SalaryEditor client:load />
          <ThemeToggle client:load />
        </div>
      </header>

      <main class="flex-1 overflow-y-auto p-4 md:p-6">
        <slot />
      </main>
    </div>
  </div>
  <Toaster client:load />
</Layout>
