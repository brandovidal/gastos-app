generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== GRUPOS PRESUPUESTARIOS ====================

model BudgetGroup {
  id         String   @id @default(cuid())
  name       String   @unique
  emoji      String   @default("📦")
  percentage Float    @default(0)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categories Category[]

  @@map("budget_groups")
}

// ==================== CATEGORÍAS DINÁMICAS ====================

model Category {
  id            String       @id @default(cuid())
  name          String       @unique
  color         String       @default("#6B7280")
  icon          String?
  isDefault     Boolean      @default(false)
  budgetGroupId String?
  budgetGroup   BudgetGroup? @relation(fields: [budgetGroupId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  fixedCosts FixedCost[]
  budgets    CategoryBudget[]

  @@index([budgetGroupId])
  @@map("categories")
}

model CategoryBudget {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  monthlyLimit   Float
  alertThreshold Float    @default(80)
  month          Int?
  year           Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([categoryId, month, year])
  @@map("category_budgets")
}

// ==================== GASTOS ====================

model FixedCost {
  id            String    @id @default(cuid())
  description   String
  amount        Float
  currency      String    @default("PEN")
  exchangeRate  Float?
  amountInPEN   Float?
  expenseType   String    @default("necesario")
  paymentStatus String    @default("no_iniciado")
  paymentDate   DateTime?
  dueDate       DateTime?
  attentionDate DateTime?
  paymentMonth  Int
  paymentYear   Int
  account       String?
  installments  String?
  person        String
  observation   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([paymentMonth, paymentYear])
  @@index([categoryId])
  @@index([paymentStatus])
  @@map("fixed_costs")
}

model Subscription {
  id            String    @id @default(cuid())
  description   String
  amount        Float
  currency      String    @default("PEN")
  exchangeRate  Float?
  amountInPEN   Float?
  expenseType   String    @default("necesario")
  paymentStatus String    @default("no_iniciado")
  period        String
  person        String
  account       String?
  paymentMonth  Int
  paymentYear   Int
  paymentDate   DateTime?
  dueDate       DateTime?
  comment       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([paymentMonth, paymentYear])
  @@map("subscriptions")
}

model CreditCard {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  billingCloseDay Int
  paymentDueDay   Int
  color           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses CreditCardExpense[]

  @@map("credit_cards")
}

model CreditCardExpense {
  id            String    @id @default(cuid())
  description   String
  amount        Float
  currency      String    @default("PEN")
  exchangeRate  Float?
  amountInPEN   Float?
  expenseType   String    @default("necesario")
  paymentStatus String    @default("pendiente")
  person        String
  installment   String?
  paymentMonth  Int
  paymentYear   Int
  processDate   DateTime?
  observation   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditCardId String
  creditCard   CreditCard @relation(fields: [creditCardId], references: [id])

  @@index([creditCardId, paymentMonth, paymentYear])
  @@index([paymentStatus])
  @@map("credit_card_expenses")
}

model AccountReceivable {
  id           String    @id @default(cuid())
  description  String
  amount       Float
  person       String
  status       String    @default("pendiente")
  currency     String    @default("PEN")
  exchangeRate Float?
  amountInPEN  Float?
  dueDate      DateTime?
  paidDate     DateTime?
  paidAmount   Float?
  observation  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@map("accounts_receivable")
}

// ==================== GASTOS RECURRENTES ====================

model RecurringExpense {
  id             String    @id @default(cuid())
  description    String
  amount         Float
  currency       String    @default("PEN")
  targetType     String
  targetCardCode String?
  categoryId     String?
  person         String
  account        String?
  expenseType    String    @default("necesario")
  dayOfMonth     Int
  isActive       Boolean   @default(true)
  lastGenerated  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("recurring_expenses")
}

// ==================== RESUMEN ====================

model MonthlySummary {
  id                 String   @id @default(cuid())
  month              Int
  year               Int
  salary             Float
  limitPercent       Float    @default(100)
  totalCMR           Float    @default(0)
  totalOh            Float    @default(0)
  totalIO            Float    @default(0)
  totalAMEX          Float    @default(0)
  totalFixedCosts    Float    @default(0)
  totalSubscriptions Float    @default(0)
  totalExpenses      Float    @default(0)
  totalNecesario     Float    @default(0)
  totalConCulpa      Float    @default(0)
  budgetLimit        Float    @default(0)
  surplus            Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([month, year])
  @@map("monthly_summaries")
}

// ==================== OCR ====================

model OCRProcessingLog {
  id             String   @id @default(cuid())
  fileName       String
  fileType       String
  cardType       String?
  status         String   @default("processing")
  extractedCount Int      @default(0)
  rawResponse    String?
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@map("ocr_processing_logs")
}

// ==================== AUTH (Fase posterior) ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}
